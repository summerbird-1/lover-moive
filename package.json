{
  "name": "couple-cinema",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "node node_modules/vite/bin/vite.js --host 0.0.0.0",
    "dev:server": "node node_modules/tsx/dist/cli.mjs watch server/index.ts",
    "build": "tsc --noEmit && node node_modules/vite/bin/vite.js build",
    "start": "node node_modules/tsx/dist/cli.mjs server/index.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "express": "^4.18.3",
    "lucide-react": "^0.468.0",
    "nanoid": "^4.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^4.5.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/ws": "^8.5.10",
    "concurrently": "^8.2.2",
    "tsx": "^3.14.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=16.17"
  }
}
